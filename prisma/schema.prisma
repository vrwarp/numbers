generator client {
  provider = "prisma-client-js"
  // "native" for local dev; the pinned target matches the Docker runtime image
  // (node:22-bookworm-slim = debian-openssl-3.0.x) regardless of the build host.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  firebaseUid    String?         @unique
  email          String          @unique
  fullName       String?
  mailingAddress String?
  // Verified mirror of roster-granted roles (see docs/ESIGN_DESIGN.md §5.5):
  // written only from signature-verified GRANT_ROLE/REVOKE_ROLE events.
  role           String          @default("member") // member | approver | secretary | chairman | treasurer | admin
  // Custom approval-role assignments (Positions). A pure app-layer routing
  // label — being a Position holder grants NO authority; the holder still needs
  // a real Approver+ roster grant to actually sign an approval.
  positionHolders PositionHolder[]
  // E-sign allowlist (A8): admin-managed app-surface gate under the master
  // switch. Gates ONLY who can see/enroll/run ceremonies in this app — never
  // roster validity (signatures collected while allowed stay valid forever).
  esignAllowed   Boolean         @default(false)
  // Self-service duty pauses (A10): a role-holder switching a duty off on
  // their profile. App-surface routing only, same posture as esignAllowed —
  // paused approvers vanish from the approver picker and refuse NEW
  // submissions (claims already assigned stay decidable); a paused treasurer
  // loses the finance queue/mark-paid; a paused admin loses the admin
  // surfaces. Never a role change: User.role stays the verified roster
  // mirror, and ledger validity ignores these flags entirely.
  approvalsPaused Boolean        @default(false)
  financePaused   Boolean        @default(false)
  adminPaused     Boolean        @default(false)
  locale         String          @default("en") // UI language: en | zh-Hans | zh-Hant
  // Treasurer batch-print toolbar toggles (docs/ESIGN_DESIGN.md §6.1). Persisted
  // per-user so the choice follows the account across devices. Both default OFF:
  // the lean output is just the CFCC forms; receipts and the signature
  // certificate are opt-in. Plain UI preference, never audited.
  printIncludeReceipts    Boolean @default(false)
  printIncludeCertificate Boolean @default(false)
  // Push notifications (docs/NOTIFICATIONS_DESIGN.md §8.2): master switch is
  // opt-in; categories default on but are consulted ONLY when the master is
  // on, and only at SEND time — enqueue is unconditional so the in-app
  // activity list serves push-less users identically (§5 parity).
  notifyEnabled       Boolean @default(false)
  notifySigning       Boolean @default(true) // claims awaiting your signature (named approver)
  notifyClaimProgress Boolean @default(true) // your own claims: approved / needs changes / paid
  notifyFinance       Boolean @default(true) // treasurer duty: approved claims awaiting payment
  notifySecurity      Boolean @default(true) // new-device requests (§8.5)
  // Discreet previews (§8.2): outcome- and name-neutral push bodies for lock
  // screens that family members see; details only after tap.
  notifyDiscreet      Boolean @default(false)
  // Server-side notification UI state (§8.2/§8.4): nudge dismissals + iOS
  // onboarding resume step, per ACCOUNT (a shared browser's dismissal must
  // not hide the feature from the next person). JSON — UI state, not
  // preferences; never audited.
  notifyUiStateJson   String  @default("{}")
  // E-sign setup-nudge state (docs/ESIGN_SETUP_DISCOVERABILITY.md): JSON object
  // of self-serve dismissal/decay/one-shot marks, written ONLY through the
  // per-key monotonic merge in PATCH /api/esign/nudges. Plain UI preference —
  // never audited, and NEVER surfaced to admins (a declined nudge must not
  // become a visible refusal list).
  esignNudgesJson         String  @default("{}")
  // "Prefers paper" — recorded by an officer AFTER a real conversation (the
  // Members page). Silences every setup nudge for this user. Deliberately a
  // human-entered fact, never inferred from in-app dismissals; writes are
  // audited with the target user id (allowlist precedent).
  prefersPaper            Boolean @default(false)
  createdAt      DateTime        @default(now())
  receipts       Receipt[]
  reimbursements Reimbursement[]
  extractionLogs ExtractionLog[]
  auditEvents    AuditEvent[]
  signerIdentity SignerIdentity?
  searchHistory  SearchHistory[]
  // Team memberships (read-only visibility groups over budget categories).
  teamMembers    TeamMember[]
  pushTokens       PushToken[]
  notificationJobs NotificationJob[]
  feedbackReports  FeedbackReport[]
}

model Receipt {
  id             String                 @id @default(cuid())
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  filePath       String // relative to DATA_DIR, e.g. uploads/<userId>/<id>.webp
  // Pristine copy of the uploaded image, written lazily the first time the
  // rotate/crop tool overwrites filePath. NULL until then (the stored file is
  // still the original). Lets the editor restore the original upload.
  originalFilePath String?
  mimeType       String // image/webp (image/jpeg on legacy rows) | application/pdf
  originalName   String
  sizeBytes      Int
  // "processed" = appears on ≥1 GENERATED claim (a cache maintained at PDF
  // generation and revert). Any receipt may join any number of claims.
  status         String                 @default("unassigned") // unassigned | processed
  // Optional user-written description, set at upload or edited on the card;
  // shown everywhere the receipt is shown (Shoebox, review, PDF appendix).
  note           String                 @default("")
  // Stamped by AI annotation — normally by the background ExtractionJob worker
  // shortly after upload, else inline at claim creation for receipts the worker
  // hasn't reached; empty/null until then. purchaseDate is a transcription of
  // what is printed ("YYYY-MM-DD"), never used for arithmetic. extracted*Cents
  // feed the review UI's net-amount derivation ("charged X − refunded Y").
  merchant             String  @default("")
  purchaseDate         String  @default("")
  extractedTotalCents  Int?
  extractedRefundCents Int?
  // One-line "what was purchased" transcription; with merchant/purchaseDate it
  // composes the initial line-item description when the receipt joins a claim.
  extractedSummary     String  @default("")
  // When the current annotation (the five fields above) was produced; NULL =
  // never annotated → claim creation falls back to inline extraction. An image
  // edit clears it (a crop can change what the receipt says) unless the
  // annotation is human-typed.
  annotatedAt          DateTime?
  // "ai" | "manual" ("" until annotated). "manual" (the review screen's
  // manual-entry dialog) outranks the worker: the background job never
  // overwrites a human transcription.
  annotationSource     String  @default("")
  // sha256 (hex) of the stored file bytes, stamped wherever the file is
  // (re)written — upload, image edit, restore — and lazily at first embed for
  // pre-feature rows. Lets the search reconcile sweep detect staleness without
  // re-reading files off disk (docs/SEARCH_DESIGN.md §4).
  fileSha256           String  @default("")
  createdAt      DateTime               @default(now())
  lineItems      LineItem[]
  reimbursements ReimbursementReceipt[]

  @@index([userId, status])
}

model Reimbursement {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String                 @default("draft") // draft | generated
  // Sum of non-excluded line items, in cents. Recomputed on every change.
  totalCents  Int                    @default(0)
  // Single-ministry mode: the claim-level ministry/event mirror onto every
  // non-excluded row (fan-out in the claim PATCH route). A UI-level
  // convenience, not a row lock — LineItem.ministry stays the source of truth
  // for the PDF and rows may still be patched directly via the API. New claims
  // default to single (most claims are for one ministry); pre-existing claims
  // were migrated to multi to preserve their behavior.
  singleMinistry   Boolean @default(true)
  claimMinistry    String  @default("")
  claimEvent       String  @default("")
  // The user's one-sentence "what is this claim for", kept both as the input
  // to the ministry-suggestion AI call and as a human-readable claim note.
  claimDescription String  @default("")
  // Capability token behind the QR stamp on the generated PDF: GET /c/<token>
  // serves the latest generated packet with no sign-in (the unguessable token
  // IS the credential — never expose the claim id in the link). Minted at
  // first PDF generation and kept stable across revert/re-generate cycles so
  // a printed QR always resolves to the newest version.
  publicToken String? @unique
  // --- E-sign workflow (docs/ESIGN_DESIGN.md) -------------------------------
  // Status gains submitted | rejected | approved | paid. These columns are the
  // server-side MIRROR of the signature ledger — presentation/routing only;
  // cryptographic truth lives in the ledger events (verified client-side and
  // in the report pipeline before any of these are written).
  approverUserId     String?
  signatureLedgerId  String?
  signatureLedgerKey String?
  // SHA-256 (hex) of the currently archived signed packet version.
  packetSha256       String?
  // SHA-256 (hex) of the archived APPROVED COPY — the signed packet with the
  // approver's ink/name/date stamped on, mirrored from the APPROVE event's
  // approvedPacketSha256. Default download once approved/paid; null before
  // approval and on pre-feature approvals.
  approvedPacketSha256 String?
  // Lifetime submission counter (thread seq source). NEVER reset, revert included.
  submitSeq          Int     @default(0)
  // Preflight-pinned pending ceremony payloads, JSON object keyed by signer
  // userId — at most one pending action per (claim, signer). See §5.5.
  pendingActionsJson String  @default("{}")
  // Stamped on every successful PDF generation (draft → generated). The
  // discoverability metrics and the paper-repeat nudge key on it — there is
  // deliberately no AuditEvent for generation (the evidentiary trail is not
  // telemetry), so this timestamp is the one record of when a packet was built.
  generatedAt DateTime?
  submittedAt DateTime?
  decidedAt   DateTime?
  paidAt      DateTime?
  checkNumber String    @default("")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  lineItems   LineItem[]
  receipts    ReimbursementReceipt[]
  extractionLogs ExtractionLog[]
  auditEvents    AuditEvent[]
  signatureRecords SignatureRecord[]

  @@index([userId, status])
  @@index([approverUserId, status])
}

// --- E-sign tables (docs/ESIGN_DESIGN.md §9.1) -------------------------------

// Single row (app-enforced), written once by the root's bootstrap ceremony.
// Relays the roster ledger pointer + key to enrolled clients. The root public
// key here is a CONVENIENCE COPY — verifiers anchor on the out-of-band pin
// (ESIGN_ROOT_FINGERPRINT / TOFU), never on this row alone (§4.6).
model EsignRegistry {
  id              String   @id @default(cuid())
  rosterLedgerId  String
  rosterLedgerKey String
  rootPublicKey   String
  rootUserId      String
  consentVersion  String   @default("ueta-v1")
  // Master switch (admin-toggled, OFF by default): ceremonies, queues, and
  // enrollment refuse while disabled. Verification of already-signed records
  // (/v, packet, certificate) stays available — retention never turns off.
  enabled         Boolean  @default(false)
  // Rollout scope while enabled (A8): "allowlist" admits only members with
  // User.esignAllowed (admins always pass); "everyone" opens it to all users.
  scope           String   @default("allowlist")
  createdAt       DateTime @default(now())
}

// Verified mirror of a member's roster state (written per §5.5 only — never
// from client assertions). Feeds pickers/badges; the roster is the truth.
model SignerIdentity {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey  String    @default("") // base64 SPKI, filled once the roster keypair exists
  // Hand-drawn signature (PNG data URL, transparent background), captured on a
  // touch screen or with the mouse at enrollment. Stamped onto the PDF's
  // signature lines: the requestor's at packet generation (inside the
  // hash-bound bytes), the approver's onto the certificate delivery copy.
  // Its SHA-256 rides inside every ceremony payload the member signs.
  signatureImage String @default("")
  status     String    @default("pending") // pending | attested | revoked
  attestedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Raw ledger event docs as reported by clients — the server cannot read
// Firestore itself (keyless), so this is the certificate/offline-bundle
// material AND the input to server-side verification. Append-only.
model LedgerEventMirror {
  id            String    @id @default(cuid())
  ledgerId      String
  eventId       String
  createdAtMs   BigInt
  encryptedData String
  iv            String
  kind          String    @default("") // decrypted action `t`, once verified
  verifiedAt    DateTime?

  @@unique([ledgerId, eventId])
  @@index([ledgerId])
}

// Verified mirror of claim-ledger actions; outlives the claim (retention).
model SignatureRecord {
  id              String         @id @default(cuid())
  reimbursementId String?
  reimbursement   Reimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: SetNull)
  kind            String // submit | approve | reject | paid | withdraw
  signerUserId    String
  signerPublicKey String
  typedName       String   @default("")
  packetSha256    String
  payloadJson     String // the exact signed action (seq/refs/consent inside)
  actionHash      String   @unique // idempotency key (§5.5)
  ledgerEventId   String
  createdAt       DateTime @default(now())

  @@index([reimbursementId])
}

// Retention pointer written at first submission and NEVER deleted — keeps
// certificates and /v/<token> working after the claim row itself is gone.
model EsignClaimArchive {
  claimId     String   @id // plain string on purpose (no FK — survives deletion)
  userId      String
  ledgerId    String
  ledgerKey   String
  publicToken String
  createdAt   DateTime @default(now())

  @@index([publicToken])
}

// ESIGN_MOCK=1 ledger backend: an append-only event store with the same
// semantics as the Firestore rules (server-stamped createdAt, create-once
// event ids, ciphertext readable by any signed-in user). Dev/test only —
// empty in real deployments, where events live in Firestore.
model EsignMockEvent {
  id            Int      @id @default(autoincrement())
  ledgerId      String
  eventId       String
  encryptedData String
  iv            String
  createdAt     DateTime @default(now())

  @@unique([ledgerId, eventId])
  @@index([ledgerId, id])
}

// ESIGN_MOCK device-sync store (docs/MULTI_DEVICE_PLAN.md M1): SQLite stand-in
// for charproof's Firestore AccountKeyStore, so the REAL charproof device/keystore
// code runs in dev/tests via provider injection. All payloads are opaque JSON the
// client already encrypted/blinded — the server never sees key material. Empty in
// real deployments (production custody rides Firestore under charproof's rules).
model EsignAccountKeys {
  userId    String   @id
  doc       String
  // Optimistic-concurrency counter standing in for Firestore transactions.
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model EsignPendingDevice {
  userId    String
  deviceId  String
  data      String
  updatedAt DateTime @updatedAt

  @@id([userId, deviceId])
}

model EsignKeystoreEntry {
  userId    String
  docId     String
  entry     String
  updatedAt DateTime @updatedAt

  @@id([userId, docId])
}

model LineItem {
  id              String        @id @default(cuid())
  reimbursementId String
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)
  receiptId       String
  receipt         Receipt       @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description     String
  // Row total in cents, negative for a net-refund receipt (integer math
  // avoids floating-point drift).
  amountCents     Int
  // The user's explicit choice, made during review; empty until picked (the
  // AI never assigns ministries, and a row cannot be verified without one).
  // Usually a budget category from MINISTRY_GROUPS but free text is allowed
  // ("Other" in the UI).
  ministry        String        @default("")
  // Optional event label ("Summer Retreat", "Christmas Party"); combined with
  // ministry on the PDF's "For Ministry / Event" column. Never required.
  event           String        @default("")
  isVerified      Boolean       @default(false)
  isExcluded      Boolean       @default(false)
  sortOrder       Int           @default(0)
  // Snapshot of the values the AI originally extracted, frozen at claim
  // creation. Comparing them with the final values (plus the AuditEvent
  // trail) shows exactly what humans had to correct — the raw material for
  // prompt tuning. Null on human-created rows (e.g. the second half of a split).
  originalDescription String?
  originalAmountCents Int?

  @@index([reimbursementId])
}

// One row per AI call (success or failure): the exact prompt, the raw model
// response, and what was parsed from it. Kept even if the claim is later
// deleted (reimbursementId goes null) so tuning data survives.
model ExtractionLog {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reimbursementId String?
  reimbursement   Reimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: SetNull)
  // What kind of AI call this was: "receipt" (vision extraction) or
  // "suggestion" (text-only ministry/event suggestion).
  kind            String         @default("receipt")
  // Which receipt a kind="receipt" call read (no FK — logs outlive receipts).
  // A background-annotation log starts with reimbursementId NULL; when a claim
  // consumes the stored annotation it adopts the unlinked logs for its
  // receipts, so per-claim telemetry stays complete without a second AI call.
  receiptId       String?
  model           String // e.g. "google/gemini-3.1-flash-lite" or "mock"
  prompt          String
  receiptsJson    String? // metadata of the receipts sent (id, name, mime, size) — not the image bytes. Null on suggestion calls.
  rawResponse     String?
  parsedJson      String?
  status          String // success | error
  errorMessage    String?
  durationMs      Int
  createdAt       DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([reimbursementId])
  @@index([receiptId])
}

// Background receipt-annotation queue: one job per receipt, processed by the
// singleton worker (src/lib/extraction/worker.ts) at a deliberately slow pace
// (EXTRACTION_PACE_MS, default one receipt/minute) so the AI provider's request
// budget stays available for user-initiated calls. Same crash-safety shape as
// EmbeddingJob: generation-conditional finalize, lease reclaim, bounded
// retries. No FK to Receipt — the delete route and the sweep GC job rows.
model ExtractionJob {
  id             String    @id @default(cuid())
  receiptId      String    @unique
  // Denormalized owner: jobs are enqueued/read outside receipt transactions.
  userId         String
  status         String    @default("queued") // queued | running | done | failed
  // Bumped by every enqueue-upsert and by manual-entry supersede; the worker's
  // terminal write is conditional on it, so a newer intent (re-annotate after
  // an image edit, or a human transcription) can never be clobbered by a
  // still-running older job.
  generation     Int       @default(0)
  // 0 = fresh upload, 1 = backfill sweep (drained after priority 0).
  priority       Int       @default(0)
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  // Crash-safety lease: a "running" row whose lease expired is reclaimable.
  leaseExpiresAt DateTime?
  lastError      String    @default("")
  // Receipt.fileSha256 at terminal failure: the sweep re-enqueues a failed job
  // ONLY when the file changed — permanently unreadable receipts must not
  // re-burn provider calls on every sweep.
  failedFileSha256 String  @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, priority, nextAttemptAt])
  @@index([userId, status])
}

// Every manual change a user makes during review (edit, verify, exclude,
// split, ...) with a field-level before/after diff. Together with the
// LineItem.original* snapshot this is the "what did the human fix" record.
model AuditEvent {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reimbursementId String?
  reimbursement   Reimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: SetNull)
  lineItemId      String? // plain string on purpose: survives line-item deletion
  action          String // update | manual-entry | split | merge | add-receipt | remove-receipt | revert-to-draft | create-claim | generate-pdf | edit-receipt-image | restore-receipt-image
  detail          String // JSON, e.g. {"changes":{"amountCents":{"from":864,"to":725}}}
  createdAt       DateTime       @default(now())

  @@index([reimbursementId])
  @@index([userId, createdAt])
}

// User-initiated feedback / bug report (docs/FEEDBACK_DESIGN.md). One row per
// submission. Shape mirrors ExtractionLog/AuditEvent house style: cuid id,
// denormalized userId with Cascade, JSON-in-String payload columns, free-string
// status, @@index([userId, createdAt]). This is the high-signal, human-initiated
// tier — passive breadcrumbs/crash crumbs ride along INSIDE diagnosticsJson, they
// are never their own rows (docs/FEEDBACK_DESIGN.md §2). Privacy: the client
// redacts before it ever POSTs — diagnosticsJson holds SHAPES not values (route
// templates, API {method,path,status,code}, console/error stacks), never money,
// descriptions, tokens, or other members' data (invariants 2/7/11/12 posture).
model FeedbackReport {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "bug" | "confused" | "idea" | "crash" — the severity/situation the user
  // (or the error boundary, for "crash") tagged. Free string like every other
  // status column here; the client maps it to a Feedback.* label.
  category        String         @default("bug")
  // Which situation chip was tapped (e.g. "upload" | "stuck" | "amount" |
  // "other"), pre-tagging the stage for triage. "" when none.
  situation       String         @default("")
  // The user's optional free text (may be empty — a tagged wordless report is
  // still a report). Capped client- and server-side.
  message         String         @default("")
  // Route TEMPLATE the report was filed from (e.g. "/claims/[id]"), never a
  // concrete path with ids/query.
  route           String         @default("")
  // Build identity so a report names its deploy (BUILD_SHA at build time; ""
  // in dev). Redacted diagnostics bundle (breadcrumbs, env, recent request-ids,
  // crash stack) as a JSON string — see src/lib/feedback/diagnostics.ts.
  buildSha        String         @default("")
  diagnosticsJson String         @default("{}")
  locale          String         @default("en")
  userAgent       String         @default("")
  // Triage state (admin-only writes): new | triaged | closed.
  status          String         @default("new")
  createdAt       DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// Church-wide budget-category catalog — the source for the "Ministry / Fund"
// dropdown, the AI-suggestion validation set, and the treasurer's Budget
// Categories screen. GLOBAL (no userId): one deployment = one church, one
// chart of accounts — the same church-wide scope as church-context.md, not
// per-user tenant data. When the table is EMPTY the app falls back to the
// built-in DEFAULT list in src/lib/ministries.ts, so a fresh deployment works
// with no seed and the stored LineItem.ministry value (the composed
// "<code> <name>" string) is never migrated. `code` is a 3-digit account
// number (999 is reserved for uncategorized free text and never stored here);
// `name` is the editable label; their composed "<code> <name>" is exactly the
// value a pick writes to LineItem.ministry. `description` is optional
// treasurer-authored guidance — shown in the picker, never printed on the
// form and never translated (church data, like the ministry values themselves).
model Ministry {
  id          String   @id @default(cuid())
  code        String // 3-digit account code, e.g. "245"
  name        String // editable label, e.g. "Drinking Water"
  group       String   @default("") // chart-of-accounts section label
  description String   @default("") // optional guidance (never printed / translated)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Optional default approver for this category, modelled as a Position
  // (custom approval role). Purely a routing hint: at submit time the claim's
  // categories resolve to a Position → its first approval-eligible holder,
  // which pre-fills (never assigns) the approver picker. SetNull on delete so a
  // removed position simply clears the default. Archived positions don't route.
  defaultPositionId String?
  defaultPosition   Position? @relation(fields: [defaultPositionId], references: [id], onDelete: SetNull)

  @@index([active, sortOrder])
}

// A custom approval role — "Deacon of Missions", "Office Staff" — that the
// treasurer assigns to one or more people and sets as the default approver for
// budget categories (docs/agent/ARCHITECTURE.md). GLOBAL (no userId): one
// deployment = one church, the same church-wide scope as the Ministry catalog.
//
// A Position is an APP-LAYER ROUTING LABEL ONLY — exactly the posture of the
// A10 duty pauses and A8 allowlist (schema User comment): it never touches
// User.role, the roster ledger, or ledger validity. Naming someone a holder
// grants NO approval authority; they still need a signature-verified Approver+
// grant to sign an approval. The only thing a Position does is PRE-FILL the
// approver picker on a claim (the submitter still signs the approver into the
// SUBMIT payload themselves), and the decision route + offline verifier
// re-check the real role at signing time regardless.
model Position {
  id          String   @id @default(cuid())
  name        String // English name (required, the display fallback). Built-in defaults localize via Positions.builtin.<key>; custom positions localize via the optional per-locale columns below (usePositionLabel).
  nameZhHans  String? // optional Simplified Chinese name for a custom position (null = fall back to `name`)
  nameZhHant  String? // optional Traditional Chinese name for a custom position (null = fall back to `name`)
  description String   @default("") // optional guidance (never printed / translated)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  holders     PositionHolder[]
  ministries  Ministry[]

  @@index([active, sortOrder])
}

// A person assigned to a Position. `order` is the assignment order: the
// lowest-ordered approval-eligible holder is the one pre-filled (the "primary";
// the rest are backups picked up only if earlier holders can't approve).
model PositionHolder {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order      Int      @default(0)

  @@unique([positionId, userId])
  @@index([userId])
}

// A Team — a named group of members associated with budget categories
// ("Missions team", "Facilities team"). GLOBAL (no owner): church master data,
// same scope as the Ministry catalog and Positions, managed by any
// Approver-or-above (or an app-admin).
//
// Membership grants exactly ONE thing: a READ-ONLY visibility expansion
// (docs/SEARCH_DESIGN.md §6.3 team amendment). A member of an active team may
// view/list/search the receipts (and containing claims) whose line items carry
// one of the team's budget-category codes on a NON-DRAFT claim — a real
// reimbursement request. Least-privilege grain: only the receipts whose OWN
// line item matches; drafts stay private to their owner. The grant derives
// from membership re-read on every request — never from roles, ADMIN_EMAILS,
// or the roster — writes stay owner-only, and non-members get the standard
// 404. No ledger involvement of any kind.
model Team {
  id          String       @id @default(cuid())
  name        String // "Missions team" — church data, never translated
  description String       @default("") // optional guidance (never translated)
  active      Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  ministries  TeamMinistry[]

  @@index([active, sortOrder])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

// A team's budget-category association, stored as the 3-digit account CODE —
// the same stable key composed into LineItem.ministry — not a Ministry row id.
// Codes survive catalog renames (historical composed strings are never
// migrated), keep matching archived categories' history, and are readable from
// the ungated catalog GET, which the approver-level teams editor uses.
model TeamMinistry {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  code   String // 3-digit account code, e.g. "210"

  @@unique([teamId, code])
  @@index([code])
}

// --- Semantic search (docs/SEARCH_DESIGN.md) ---------------------------------

// Single row (app-enforced): the admin-editable embedding backend config.
// Seeded once from EMBEDDING_* config values; thereafter the DB row is
// authoritative and the admin card is the way to change it.
model EmbeddingSettings {
  id          String   @id @default(cuid())
  enabled     Boolean  @default(false)
  endpoint    String   @default("")
  apiKey      String   @default("") // never returned by the admin GET (fingerprint only)
  model       String   @default("") // index identity: changing it wipes + rebuilds
  dim         Int      @default(0)  // detected by the probe, not typed by admins
  // Query-side instruction prefix; queries-only, so editing never re-indexes.
  queryPrefix String   @default("")
  // Semantic score floor ×1000 (integer for SQLite hygiene). Same edit class
  // as queryPrefix: apply in place.
  minScoreMilli Int    @default(250)
  updatedAt   DateTime @updatedAt
}

// One vector per indexed document per model. targetId is a Receipt.id or
// Reimbursement.id — plain string, no FK: rows are deleted by the ingest code
// alongside their target, and the sweep GCs any survivors.
model Embedding {
  id           String   @id @default(cuid())
  kind         String // "receipt" | "claim"
  targetId     String
  // Denormalized owner + year so the search path scans ONE table with no
  // joins and applies tenant scoping before any vector math.
  userId       String
  year         Int
  model        String // which backend produced the vector — part of row identity
  dim          Int
  vector       Bytes // Float32Array little-endian, L2-normalized, length == dim
  // Fingerprint of the FULL embedding input, rebuilt from DB columns to detect
  // staleness: receipt = sha256(fileSha256‖note‖merchant‖purchaseDate);
  // claim = sha256(composite text).
  sourceSha256 String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([kind, targetId, model])
  @@index([model, userId])
}

// Durable embed work queue. One live row per (kind, targetId, model);
// re-triggering upserts in place (generation++) rather than growing the queue.
model EmbeddingJob {
  id             String    @id @default(cuid())
  kind           String // "receipt" | "claim"
  targetId       String
  // Denormalized owner so per-search "your items still indexing" counts are
  // one indexed query.
  userId         String
  model          String
  status         String    @default("queued") // queued | running | done | failed
  // Bumped by every enqueue-upsert; the worker's terminal write is conditional
  // on it, so an enqueue racing a running embed can never be lost.
  generation     Int       @default(0)
  // 0 = live event, 1 = backfill/rebuild (drained after priority 0).
  priority       Int       @default(0)
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  // Crash-safety lease: a "running" row whose lease expired is reclaimable.
  leaseExpiresAt DateTime?
  lastError      String    @default("")
  // Fingerprint at terminal failure: the sweep re-enqueues a failed job ONLY
  // when the rebuilt fingerprint differs (content changed) — permanently
  // unreadable items must not re-burn retries daily.
  failedSourceSha256 String @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([kind, targetId, model])
  @@index([status, priority, nextAttemptAt])
  @@index([userId, status])
}

// Per-user recent search queries, synced across the member's devices so the
// dropdown under the search box shows the same history everywhere (replaces the
// old localStorage-only recents — docs/SEARCH_DESIGN.md §7). Owner-scoped like
// all tenant data (hard invariant 2); one row per distinct query (re-searching
// bumps updatedAt to the top), pruned to a 90-day window on write. This is the
// user's own history shown back to them, not telemetry — invariant 11's
// "queries never in ExtractionLogs" posture is unchanged.
model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, query])
  @@index([userId, updatedAt])
}

// --- Push notifications (docs/NOTIFICATIONS_DESIGN.md) ----------------------

// One FCM registration token = one browser-profile-on-one-device. Tokens
// follow the signed-in account (sign-out deletes, §8.6); liveness is
// max(lastSeenAt, lastSendOkAt) within 180d (§7.3) — a successful send counts,
// because glance-only devices never ping. Never returned by any GET.
model PushToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique
  // This device's resolved locale, re-captured on every ping (§9) — never a
  // bare "en" default; registration falls back to User.locale.
  locale       String
  // Trimmed human label for the profile card's device list ("Safari · iPhone").
  userAgent    String    @default("")
  createdAt    DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  lastSendOkAt DateTime?

  @@index([userId])
}

// Durable notification outbox (§6/§7). One row per recipient per event —
// created UNCONDITIONALLY of push preferences (the row doubles as the in-app
// activity record, §5 parity); whether it is DELIVERED is decided at send
// time. dedupeKey makes reconcile replays and route retries no-ops. Rows are
// the send log (invariant 7) and are pruned after 90 days; payloadJson holds
// event params only (localized text is composed at send/render time, never
// stored) — it carries personal free text, owner-only read scope (§11).
model NotificationJob {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           String // signing-request | claim-approved | claim-rejected | finance-queue | claim-paid | device-request | self-test
  category       String // signing | claims | finance | security | "" (self-test: master switch only)
  targetId       String    @default("") // claimId / userId — collapse + deep link + deletion semantics
  dedupeKey      String    @unique
  payloadJson    String    @default("{}")
  status         String    @default("queued") // queued | running | sent | failed | skipped
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  // Crash-safety lease: a "running" row whose lease expired is reclaimable
  // (worker mirrors EmbeddingJob).
  leaseExpiresAt DateTime?
  lastError      String    @default("")
  createdAt      DateTime  @default(now())

  @@index([status, nextAttemptAt])
  @@index([userId, createdAt])
  @@index([targetId])
}

// Join table: a claim bundles many receipts; a receipt may (rarely) appear in
// several draft claims until one of them is generated.
model ReimbursementReceipt {
  reimbursementId String
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)
  receiptId       String
  receipt         Receipt       @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@id([reimbursementId, receiptId])
}
