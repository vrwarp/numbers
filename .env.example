# --- Core ---
# Where the SQLite database lives. In Docker this points into the /data volume.
DATABASE_URL="file:./data/numbers.db"
# Root folder for uploaded receipt files. Defaults to ./data
DATA_DIR="./data"

# --- Auth (Firebase Authentication) ---
# Session-cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# Firebase web-app config: Firebase console -> Project settings -> Your apps.
# Enable the Google provider under Authentication -> Sign-in method, and add
# your domain (e.g. numbers.example.org) to Authentication -> Authorized domains.
# These values are client-safe; the server relays them to the sign-in page.
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""   # e.g. your-project.firebaseapp.com
FIREBASE_PROJECT_ID=""
FIREBASE_APP_ID=""        # optional

# --- AI extraction (OpenRouter) ---
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Any vision-capable OpenRouter model id. Default balances receipt-OCR
# accuracy and cost (~$0.001/receipt).
OPENROUTER_MODEL="google/gemini-3.1-flash-lite"

# --- Development / testing only ---
# AI_MOCK=1 makes extraction return deterministic fake data (no API calls)
#AI_MOCK=1
# AUTH_TEST_MODE=1 enables a passwordless dev login (NEVER set in production)
#AUTH_TEST_MODE=1
