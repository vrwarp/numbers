# --- Core ---
# Where the SQLite database lives. In Docker this points into the /data volume.
DATABASE_URL="file:./data/numbers.db"
# Root folder for uploaded receipt files. Defaults to ./data
DATA_DIR="./data"

# Every setting below (all except DATABASE_URL and DATA_DIR) can also be set in
# a JSON file at <DATA_DIR>/config.json (see config.json.example), e.g.
# {"AI_PROVIDER":"google","GEMINI_API_KEY":"..."}. File values override these
# env vars and are re-read when the file changes, so a running deployment can be
# reconfigured by editing that file on the data volume — no restart needed.

# The URL users (and QR-code scanners) reach this deployment at, e.g.
# "https://numbers.example.org". When set, every generated PDF is stamped with
# a QR code linking back to its own latest version at <PUBLIC_BASE_URL>/c/<token>;
# when unset the stamp is simply omitted. The server cannot infer this behind
# Docker or a reverse proxy, hence explicit configuration.
#PUBLIC_BASE_URL=""

# IANA time zone every human-facing date is computed in — "Today"/"Yesterday"
# labels, the date stamped on generated/approved claim forms, the admin usage
# chart's days. The server runs in UTC (Docker), so this is explicit rather
# than ambient. Defaults to America/Los_Angeles (Hayward, CA); also editable
# under Admin -> Settings.
#TIME_ZONE="America/Los_Angeles"

# --- Auth (Firebase Authentication) ---
# Session-cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# Firebase web-app config: Firebase console -> Project settings -> Your apps.
# Enable the Google provider under Authentication -> Sign-in method, and add
# your domain (e.g. numbers.example.org) to Authentication -> Authorized domains.
# These values are client-safe; the server relays them to the sign-in page.
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""   # e.g. your-project.firebaseapp.com
FIREBASE_PROJECT_ID=""
FIREBASE_APP_ID=""        # optional

# --- Push notifications (docs/NOTIFICATIONS_DESIGN.md; setup: docs/PUSH_SETUP.md)
# All optional — the app runs fully without them (badges/activity list remain).
# FIREBASE_MESSAGING_SENDER_ID + FIREBASE_VAPID_PUBLIC_KEY are client-safe
# (Firebase console -> Cloud Messaging). FCM_SERVICE_ACCOUNT_JSON is the ONE
# server-held Firebase credential: a service account with a CUSTOM role holding
# exactly cloudmessaging.messages.create (never "Firebase Admin" — that would
# void the e-sign keyless-ledger property). It is multi-line JSON, so the
# <DATA_DIR>/config.json overlay (or the Admin -> Settings editor) is its
# recommended home rather than this file.
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_VAPID_PUBLIC_KEY=""
#FCM_SERVICE_ACCOUNT_JSON=""
# NOTIFY_PAUSED=1 stops all sending (events still record); NOTIFY_QUIET holds
# claim-lifecycle sends inside a window, e.g. "21:30-08:00,sun:09:00-12:30"
# (off by default — device Do-Not-Disturb is usually the better tool).
#NOTIFY_PAUSED=1
#NOTIFY_QUIET=""
# PUSH_MOCK=1 records deliveries to <DATA_DIR>/push-mock.jsonl instead of FCM
# and registers synthetic tokens (dev/tests; like AI_MOCK).
#PUSH_MOCK=1

# iOS/WebKit sign-in fix. Every iOS browser is WebKit, and WebKit partitions
# third-party storage — which breaks Firebase's default sign-in flow (where the
# authDomain your-project.firebaseapp.com is a third-party origin) with
# "auth/popup-blocked" or "Unable to process request due to missing initial
# state". Set FIREBASE_AUTH_PROXY=1 to serve Firebase's /__/auth handler from
# THIS app's own origin (reverse-proxied to <FIREBASE_PROJECT_ID>.firebaseapp.com)
# and point the client authDomain at PUBLIC_BASE_URL's host, making sign-in
# first-party. Leave FIREBASE_AUTH_DOMAIN as your-project.firebaseapp.com (do NOT
# set it to your own domain — the proxy target comes from FIREBASE_PROJECT_ID).
# Requires PUBLIC_BASE_URL to be set, plus in the console:
#   - Google Cloud -> APIs & Services -> Credentials -> your OAuth client:
#     add "<PUBLIC_BASE_URL host>/__/auth/handler" to Authorized redirect URIs
#   - Firebase -> Authentication -> Settings -> Authorized domains:
#     add the PUBLIC_BASE_URL host
#FIREBASE_AUTH_PROXY=1

# --- AI extraction ---
# Backend for receipt extraction: "openrouter" (default) or "google"
# (Google AI Studio / Gemini API, called directly).
AI_PROVIDER="openrouter"

# OpenRouter (AI_PROVIDER=openrouter): API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Any vision-capable OpenRouter model id. Default balances receipt-OCR
# accuracy and cost (~$0.001/receipt).
OPENROUTER_MODEL="google/gemini-3.1-flash-lite"

# Google AI Studio (AI_PROVIDER=google): API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Any vision-capable Gemini model id.
GEMINI_MODEL="gemini-3.1-flash-lite"

# Church-context document fed into the "Suggest" ministry/event feature: a
# small markdown file with church-specific vocabulary (group names, recurring
# events, labeling rules). See docs/church-context.example.md for the template.
# Defaults to <DATA_DIR>/church-context.md; the feature degrades gracefully
# (chart-of-accounts knowledge only) when the file is absent. NOTE: its
# contents are sent to the AI provider with every suggestion request.
#CHURCH_CONTEXT_PATH="./data/church-context.md"

# Admin area (/admin) access. Comma/space-separated emails granted admin access
# WITHOUT going through the e-sign roster bootstrap — the simplest way to seed a
# deployment's first admin. App-surface only: it never writes the verified
# roster role, so e-sign signing/validity is untouched. Empty → admin is only
# the roster-granted role. Also editable in-app under Admin → Settings.
#ADMIN_EMAILS="you@example.org, other@example.org"

# Rate limiting / quota retries. Extraction is throttled to AI_RPM_TARGET
# requests/minute (Gemini's free tier is 15). On a quota/rate-limit error the
# server waits AI_QUOTA_COOLDOWN_MS and retries up to AI_QUOTA_MAX_RETRIES times,
# surfacing the wait to the user. Defaults shown.
AI_RPM_TARGET="15"
AI_QUOTA_COOLDOWN_MS="60000"
AI_QUOTA_MAX_RETRIES="3"

# --- E-signature & approval workflow (docs/ESIGN_DESIGN.md) ---
# Email of the trust root — the only account allowed to run the one-time
# "Initialize signing registry" bootstrap on their profile page. Unset →
# e-sign stays dormant and the classic print-and-sign flow is unchanged.
#ESIGN_ROOT_EMAIL="treasurer@example.org"
# Optional out-of-band root anchor: ≥32 hex chars of the root key's SHA-256
# fingerprint (shown at bootstrap). When set, clients and server refuse any
# registry that doesn't match — set it right after bootstrapping.
#ESIGN_ROOT_FINGERPRINT=""
# Production ledgers live in Cloud Firestore: enable Firestore in the Firebase
# project and deploy the repo's forked rules (firebase deploy --only
# firestore:rules), then confirm with `node scripts/check-rules.mjs`.

# --- Development / testing only ---
# AI_MOCK=1 makes extraction return deterministic fake data (no API calls)
#AI_MOCK=1
# AUTH_TEST_MODE=1 enables a passwordless dev login (NEVER set in production)
#AUTH_TEST_MODE=1
# ESIGN_MOCK=1 swaps Firestore for an append-only SQLite ledger store and
# local key custody — the full signing protocol (real ECDSA, hash binding,
# thread rules) runs without a Firebase project (dev/tests only)
#ESIGN_MOCK=1
# E-sign against the REAL Firestore backend via the Firebase emulator suite
# (docs/agent/TESTING.md): leave ESIGN_MOCK unset, run `npm run esign:emulators`,
# and set the SDK-standard host pair below (never in production). A demo
# project id is enough — no credentials.
#FIREBASE_PROJECT_ID=demo-numbers
#FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
#FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
