{
  "name": "numbers",
  "version": "1.0.0",
  "private": true,
  "description": "CFCC Reimbursement App — shoebox receipt capture, AI extraction, human-verified PDF generation",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "node -e \"const fs=require('fs');if(fs.existsSync('prisma/schema.prisma')){require('child_process').execSync('prisma generate',{stdio:'inherit'})}\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "translate": "tsx scripts/translate-messages.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "esign:emulators": "firebase emulators:start --only auth,firestore",
    "esign:rules-canary": "node scripts/check-rules.mjs",
    "test:e2e:esign": "playwright test -c playwright.esign.config.ts",
    "test:e2e:esign:local": "firebase emulators:exec --only auth,firestore --project demo-numbers \"npm run test:e2e:esign\"",
    "test:e2e:esign:docker": "docker build -t numbers-esign-e2e -f Dockerfile.e2e . && docker run --rm -e CI -v ~/.cache/firebase/emulators:/root/.cache/firebase/emulators numbers-esign-e2e"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.16.0",
    "charproof": "^1.0.8",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "fontkit": "^2.0.4",
    "next": "^15.5.0",
    "next-intl": "^4.13.2",
    "pdf-lib": "^1.17.1",
    "qr-scanner": "^1.4.2",
    "qrcode-generator": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "firebase-tools": "^15.23.0",
    "pdfjs-dist": "^6.1.200",
    "prisma": "^6.16.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
